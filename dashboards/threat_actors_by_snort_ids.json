{
    "title": "Threat Actor by Snort IDs",
    "description": "Utilize this panel to correlate Snort intrusion events with known threat actors. Configure the Snort-ID-to-Threat-Actor lookup to enrich incoming signature data and populate the “Threat Actors by Snort IDs” view.",
    "inputs": {
        "input_global_trp": {
            "options": {
                "defaultValue": "-24h@h,now",
                "token": "global_time"
            },
            "title": "Global Time Range",
            "type": "input.timerange"
        },
        "input_tlWhhLwR": {
            "dataSources": {
                "primary": "ds_i58D84BP"
            },
            "options": {
                "items": [
                    {
                        "label": "All Threat Actors",
                        "value": "*"
                    }
                ],
                "token": "threat_actor_token"
            },
            "title": "Threat Actor",
            "type": "input.dropdown"
        }
    },
    "defaults": {
        "dataSources": {
            "ds.search": {
                "options": {
                    "queryParameters": {
                        "earliest": "$global_time.earliest$",
                        "latest": "$global_time.latest$"
                    }
                }
            }
        }
    },
    "visualizations": {
        "viz_LbI09I1U": {
            "dataSources": {
                "primary": "ds_7sRMJ3vQ"
            },
            "options": {},
            "type": "splunk.table"
        },
        "viz_kpJB7bW3": {
            "containerOptions": {},
            "dataSources": {
                "primary": "ds_mGcuwEO0"
            },
            "description": "Matching Snort Intrusion Events within a time_window of 1d",
            "showLastUpdated": false,
            "showProgressBar": false,
            "title": "Snort Intrusion Events - By Threat Actor",
            "type": "splunk.table"
        }
    },
    "dataSources": {
        "ds_7sRMJ3vQ": {
            "name": "snort_ids_threat_actor",
            "options": {
                "query": "|inputlookup snort_ids_threat_actor.csv \n|  table threat_actor signature_id description"
            },
            "type": "ds.search"
        },
        "ds_i58D84BP": {
            "name": "lookup_threat_actors",
            "options": {
                "query": "|inputlookup snort_ids_threat_actor.csv | table threat_actor"
            },
            "type": "ds.search"
        },
        "ds_mGcuwEO0": {
            "name": "cisco_events_match",
            "options": {
                "query": "`cisco_secure_firewall` EventType=IntrusionEvent \n| bin _time span=1d\n| stats count as Total_Alerts dc(signature_id) as sig_count \n        values(signature_id) as signature_ids \n        values(signature) as signature \n        values(class_desc) as class_desc \n        values(MitreAttackGroups) as MitreAttackGroups \n        values(InlineResult) as InlineResult \n        values(InlineResultReason) as InlineResultReason \n        values(src_ip) as src_ip \n        values(dest_port) as dest_port \n        values(rule) as rule \n        values(transport) as transport \n        values(app) as app\n        by dest_ip _time\n| eval sig_ids_str = mvjoin(signature_ids, \",\")\n| lookup snort_ids_threat_actor.csv signature_id as sig_ids_str OUTPUT threat_actor, distinct_count_snort_ids, description\n| where isnotnull(threat_actor) AND sig_count >= tonumber(distinct_count_snort_ids)\n| `security_content_ctime(firstTime)`\n| `security_content_ctime(lastTime)`\n| table _time threat_actor description dest_ip signature_ids signature src_ip  MitreAttackGroups\n|  search threat_actor=\"$threat_actor_token$\"",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            },
            "type": "ds.search"
        }
    },
    "layout": {
        "globalInputs": [
            "input_global_trp",
            "input_tlWhhLwR"
        ],
        "layoutDefinitions": {
            "layout_1": {
                "structure": [
                    {
                        "item": "viz_LbI09I1U",
                        "position": {
                            "h": 149,
                            "w": 1200,
                            "x": 0,
                            "y": 0
                        },
                        "type": "block"
                    },
                    {
                        "item": "viz_kpJB7bW3",
                        "position": {
                            "h": 400,
                            "w": 1200,
                            "x": 0,
                            "y": 149
                        },
                        "type": "block"
                    }
                ],
                "type": "grid"
            },
            "layout_gX58DqID": {
                "structure": [],
                "type": "grid"
            }
        },
        "options": {
            "submitButton": true,
            "submitOnDashboardLoad": true
        },
        "tabs": {
            "items": [
                {
                    "label": "Threat Actors and Snort IDs mapping",
                    "layoutId": "layout_1"
                },
                {
                    "label": "New tab",
                    "layoutId": "layout_gX58DqID"
                }
            ]
        }
    }
}