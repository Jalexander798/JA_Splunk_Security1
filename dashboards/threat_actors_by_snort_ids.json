    "dataSources": {
        "ds_0SEcxnrn": {
            "name": "risk_events",
            "options": {
                "enableSmartSources": true,
                "query": "| from datamodel Risk.All_Risk | rename normalized_risk_object AS dest_ip | search dest_ip = $dest_ip$\n| stats\n    count                   AS Risk_Event_Count\n    min(_time)              AS firstTime\n    max(_time)              AS lastTime\n    values(search_name)     AS raw_search_names\n    values(analyticstories) AS \"Analytic Stories\"\n    values(annotations._all) AS Annotations\n    values(annotations.mitre_attack.mitre_tactic) AS \"ATT&CK Tactics\"\n  BY dest_ip src_ip\n| mvexpand raw_search_names\n| rename raw_search_names AS \"Search Name\"\n| `security_content_ctime(firstTime)` | `security_content_ctime(lastTime)`\n| table firstTime lastTime dest_ip, \"Search Name\", Risk_Event_Count"
            },
            "type": "ds.search"
        },
        "ds_70zt6tTO": {
            "name": "affected_hosts",
            "options": {
                "extend": "ds_mGcuwEO0",
                "query": "| search threat_actor=\"$threat_actor_token$\"\n| stats count by dest_ip\n| rename dest_ip as \"Private IP Address\"\n| table \"Private IP Address\""
            },
            "type": "ds.chain"
        },
        "ds_7LZlDEZh": {
            "name": "Top Source IP count",
            "options": {
                "query": "`cisco_secure_firewall` EventType=ConnectionEvent dest_ip = $dest_ip$\n| stats count BY  dest_ip  src_ip connection_id | sort count"
            },
            "type": "ds.search"
        },
        "ds_7sRMJ3vQ": {
            "name": "snort_ids_threat_actor",
            "options": {
                "query": "|inputlookup snort_ids_threat_actor.csv \n|  table threat_actor signature_id description distinct_count_snort_ids"
            },
            "type": "ds.search"
        },
        "ds_8sclv3pU": {
            "name": "Timeline",
            "options": {
                "query": "`cisco_secure_firewall` EventType=IntrusionEvent \n| bin _time span=1d\n| stats count AS Total_Alerts dc(signature_id) AS sig_count\n        values(signature_id)       AS signature_ids\n        values(signature)          AS signature\n        values(class_desc)         AS class_desc\n        values(MitreAttackGroups)  AS MitreAttackGroups\n        values(InlineResult)       AS InlineResult\n        values(InlineResultReason) AS InlineResultReason\n        values(src_ip)             AS src_ip\n        values(dest_port)          AS dest_port\n        values(rule)               AS rule\n        values(transport)          AS transport\n        values(app)                AS app\n  BY dest_ip, _time\n| eval sig_ids_str = mvjoin(signature_ids, \",\")\n| lookup snort_ids_threat_actor.csv signature_id AS sig_ids_str \n    OUTPUT threat_actor, distinct_count_snort_ids, description\n| where isnotnull(threat_actor) \n    AND sig_count >= tonumber(distinct_count_snort_ids)\n| mvexpand signature_ids\n| rename signature_ids AS signature_id\n| where threat_actor=\"$threat_actor_token$\"\n| timechart span=1h count BY signature_id"
            },
            "type": "ds.search"
        },
        "ds_TPwx4BWO": {
            "name": "affected_dest_ip",
            "options": {
                "enableSmartSources": true,
                "query": "`cisco_secure_firewall` EventType=IntrusionEvent \n| bin _time span=1d \n| stats count as Total_Alerts dc(signature_id) as sig_count \n    values(signature_id) as signature_ids \n    values(signature) as signature \n    values(class_desc) as class_desc \n    values(MitreAttackGroups) as MitreAttackGroups \n    values(InlineResult) as InlineResult \n    values(InlineResultReason) as InlineResultReason \n    values(src_ip) as src_ip \n    values(dest_port) as dest_port \n    values(rule) as rule \n    values(transport) as transport \n    values(connection_id) as connection_id\n    values(app) as app\n    by dest_ip _time \n| eval sig_ids_str = mvjoin(signature_ids, \",\") \n| lookup snort_ids_threat_actor.csv signature_id as sig_ids_str OUTPUT threat_actor, distinct_count_snort_ids, description \n| where isnotnull(threat_actor) AND sig_count >= tonumber(distinct_count_snort_ids) \n| `security_content_ctime(firstTime)` \n| `security_content_ctime(lastTime)`\n| search threat_actor = \"$threat_actor_token$\"\n| table _time threat_actor description dest_ip signature_ids signature src_ip MitreAttackGroups\n| stats count by dest_ip\n| rename dest_ip as \"Private IP Address\"\n| table \"Private IP Address\"",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            },
            "type": "ds.search"
        },
        "ds_WUBFSCV7": {
            "name": "file_event_by_dvc",
            "options": {
                "query": "`cisco_secure_firewall` EventType= FileEvent \n| bin _time span=1d \n| stats count dc(file_name) values(FileDirection) values(FileType) values(src_ip) values(dest_ip) values(ClientApplication) by dvc _time \n| join type=inner dvc \n    [ | search `cisco_secure_firewall` EventType=IntrusionEvent \n    | bin _time span=1d \n    | stats count as Total_Alerts dc(signature_id) as sig_count \n        values(signature_id) as signature_ids \n        values(signature) as signature \n        values(class_desc) as class_desc \n        values(MitreAttackGroups) as MitreAttackGroups \n        values(InlineResult) as InlineResult \n        values(InlineResultReason) as InlineResultReason \n        values(src_ip) as src_ip \n        values(dest_port) as dest_port \n        values(rule) as rule \n        values(transport) as transport \n        values(connection_id) as connection_id\n        values(app) as app\n        by dvc dest_ip _time \n    | eval sig_ids_str = mvjoin(signature_ids, \",\") \n    | lookup snort_ids_threat_actor.csv signature_id as sig_ids_str OUTPUT threat_actor, distinct_count_snort_ids, description \n    | where isnotnull(threat_actor) AND sig_count >= tonumber(distinct_count_snort_ids) \n    | `security_content_ctime(firstTime)` \n    | `security_content_ctime(lastTime)`\n    |  search threat_actor=\"$threat_actor_token$\"] | table _time threat_actor dvc sig_ids_str  dc(file_name) values(FileDirection) values(FileType) values(src_ip) values(dest_ip) values(ClientApplication)"
            },
            "type": "ds.search"
        },
        "ds_YybVUCKh": {
            "name": "affect_hosts_count",
            "options": {
                "extend": "ds_mGcuwEO0",
                "query": "| search threat_actor = \"$threat_actor_token$\"\n| stats dc(dest_ip)"
            },
            "type": "ds.chain"
        },
        "ds_i58D84BP": {
            "name": "lookup_threat_actors",
            "options": {
                "query": "|inputlookup snort_ids_threat_actor.csv | table threat_actor"
            },
            "type": "ds.search"
        },
        "ds_mGcuwEO0": {
            "name": "parent_base_search",
            "options": {
                "query": "`cisco_secure_firewall` EventType=IntrusionEvent \n| bin _time span=1d \n| stats count as Total_Alerts dc(signature_id) as sig_count \n    values(signature_id) as signature_ids \n    values(signature) as signature \n    values(class_desc) as class_desc \n    values(MitreAttackGroups) as MitreAttackGroups \n    values(InlineResult) as InlineResult \n    values(InlineResultReason) as InlineResultReason \n    values(src_ip) as src_ip \n    values(dest_port) as dest_port \n    values(rule) as rule \n    values(transport) as transport \n    values(connection_id) as connection_id\n    values(app) as app\n    by dest_ip _time \n| eval sig_ids_str = mvjoin(signature_ids, \",\") \n| lookup snort_ids_threat_actor.csv signature_id as sig_ids_str OUTPUT threat_actor, distinct_count_snort_ids, description \n| where isnotnull(threat_actor) AND sig_count >= tonumber(distinct_count_snort_ids) \n| `security_content_ctime(firstTime)` \n| `security_content_ctime(lastTime)`\n| table _time threat_actor description dest_ip signature_ids signature src_ip MitreAttackGroups connection_id",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            },
            "type": "ds.search"
        },
        "ds_mWvtZ0jy": {
            "name": "snort_events_by_actor",
            "options": {
                "extend": "ds_mGcuwEO0",
                "query": "|  search threat_actor=\"$threat_actor_token$\""
            },
            "type": "ds.chain"
        },
        "ds_ta3O0H2Z": {
            "name": "map_connection_events",
            "options": {
                "query": "`cisco_secure_firewall` EventType=ConnectionEvent dest_ip = $dest_ip$\n| iplocation src_ip\n| geostats count BY src_ip"
            },
            "type": "ds.search"
        },
        "ds_tp3k6kI6": {
            "name": "connection_raw_event",
            "options": {
                "query": "`cisco_secure_firewall`  dest_ip = $dest_ip$ connection_id=$connection_id$"
            },
            "type": "ds.search"
        },
        "ds_tuaeoaIh": {
            "name": "all_intrusion_events",
            "options": {
                "query": "`cisco_secure_firewall` EventType=IntrusionEvent dest_ip = $dest_ip$\n| bin _time span=1d \n| stats count as intrusion_count\n    by _time"
            },
            "type": "ds.search"
        },
        "ds_z10zC280": {
            "name": "file_events",
            "options": {
                "extend": "ds_mGcuwEO0",
                "query": "| join type=inner dest_ip [\n    search `cisco_secure_firewall` EventType=FileEvent\n    | bin _time span=1d\n    | stats count, dc(file_name) as \"File Count\", values(FileDirection) as Direction, values(FileType) as \"File Type\", values(dest_ip) , values(ClientApplication) BY src_ip _time | rename src_ip as dest_ip\n]\n| table _time dest_ip threat_actor \"File Count\" Direction \"File Type\" signature\n| search dest_ip=\"$dest_ip$\" threat_actor=\"$threat_actor_token$\"\n\n\n"
            },
            "type": "ds.chain"
        }
    },
